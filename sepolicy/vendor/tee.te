read_fstab(tee)

set_prop(tee, vendor_trusty_storage_prop)

wakelock_use(tee)

allow tee block_device:dir search;
allow tee mnt_vendor_file:dir search;
allow tee persist_file:dir search;
allow tee persist_ss_file:dir r_dir_perms;
allow tee persist_ss_file:lnk_file read;
allow tee sg_device:chr_file rw_file_perms;
allow tee tee_data_file:lnk_file { create getattr read };
allow tee tee_persist_block_device:blk_file rw_file_perms;
allow tee tee_userdata_block_device:blk_file rw_file_perms;
