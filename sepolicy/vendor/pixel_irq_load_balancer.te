type pixel_irq_load_balancer, domain;
type pixel_irq_load_balancer_exec, exec_type, file_type, vendor_file_type;

init_daemon_domain(pixel_irq_load_balancer)

allow pixel_irq_load_balancer proc_irq:dir r_dir_perms;
allow pixel_irq_load_balancer proc_irq:file { rw_file_perms setattr };
allow pixel_irq_load_balancer self:capability { chown setgid setuid };
allow pixel_irq_load_balancer sysfs_irq:dir r_dir_perms;
allow pixel_irq_load_balancer sysfs_irq:file r_file_perms;
