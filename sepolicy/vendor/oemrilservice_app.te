type oemrilservice_app, domain;

app_domain(oemrilservice_app)

binder_call(oemrilservice_app, rild)

set_prop(oemrilservice_app, vendor_rild_prop)

allow oemrilservice_app activity_service:service_manager find;
allow oemrilservice_app content_capture_service:service_manager find;
allow oemrilservice_app hal_vendor_radio_external_service:service_manager find;
allow oemrilservice_app netstats_service:service_manager find;
allow oemrilservice_app radio_service:service_manager find;
allow oemrilservice_app registry_service:service_manager find;
allow oemrilservice_app telecom_service:service_manager find;
