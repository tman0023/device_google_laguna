type hal_plat_security, domain;
type hal_plat_security_exec, exec_type, file_type, vendor_file_type;
type hal_plat_security_service, hal_service_type, protected_service, service_manager_type;

add_service(hal_plat_security, hal_plat_security_service)

binder_call(hal_plat_security, servicemanager)

get_prop(hal_plat_security, vendor_plat_security_prop)

init_daemon_domain(hal_plat_security)

allow hal_plat_security dmabuf_system_heap_device:chr_file { ioctl open read };
allow hal_plat_security intelligence_data_file:file r_file_perms;
allow hal_plat_security priv_app:fd use;
allow hal_plat_security tee_device:chr_file { ioctl open read write };

dontaudit hal_plat_security default_android_service:service_manager add;
