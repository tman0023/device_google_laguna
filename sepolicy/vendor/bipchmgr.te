type bipchmgr, domain;
type bipchmgr_exec, exec_type, file_type, vendor_file_type;

net_domain(bipchmgr)

binder_call(bipchmgr, rild)

binder_use(bipchmgr)

init_daemon_domain(bipchmgr)

allow bipchmgr hal_vendor_radio_external_service:service_manager find;
allow bipchmgr self:netlink_route_socket nlmsg_readpriv;
